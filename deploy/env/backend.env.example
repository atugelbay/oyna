# Скопировать в /var/www/oyna/backend/.env на сервере (не коммитить).

NODE_ENV=production
PORT=3000

DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/oyna_db?schema=public"
REDIS_URL="redis://127.0.0.1:6379"

JWT_ACCESS_SECRET="сгенерируйте-длинную-случайную-строку"
JWT_REFRESH_SECRET="другая-длинная-случайная-строка"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Список origin фронта через запятую (обязательно в production для браузера)
CORS_ORIGINS=https://crm.example.com
