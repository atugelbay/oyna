# Скопируйте в .env и подставьте при необходимости.
#
# Postgres из backend/docker-compose.yml (порт 5432 на хосте):
DATABASE_URL="postgresql://oyna:oyna_secret@localhost:5432/oyna_db"

JWT_ACCESS_SECRET="change-me-min-32-characters-long-secret"
JWT_ACCESS_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-refresh-secret-different-from-access"
JWT_REFRESH_EXPIRES_IN="30d"

# CRM (Next.js), через запятую при нескольких origin
CORS_ORIGINS="http://localhost:3001"

# Важно: `npx prisma db seed` и Nest читают backend/.env — если URL указывает не на этот
# контейнер, сид попадёт в другую БД, а CRM (через API) будет видеть только данные Docker.
