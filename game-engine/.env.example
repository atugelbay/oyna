# OYNA Lasers — Station configuration example
# Copy to .env on each station laptop, fill in values
# NEVER commit .env to git. Add to .gitignore.

# =============================================================================
# STATION IDENTITY
# =============================================================================

# Unique ID of this station (matches backend records)
# Format: kebab-case, includes room number
STATION_ID=laser-matrix-01

# Venue this station belongs to
VENUE_ID=almaty-downtown

# Room type (for future multi-room support)
ROOM_TYPE=laser_matrix

# =============================================================================
# BACKEND CONNECTION
# =============================================================================

# Base URL of backend API
# Production: https://api.oyna.pro
# Staging:    https://staging-api.oyna.pro
# Dev:        https://dev-api.oyna.pro
# Nest использует префикс /api (см. CRM_ENGINE_MAPPING.md)
BACKEND_BASE_URL=http://localhost:3000/api

# Station API key (provided by admin via secure channel)
# Format: station_live_<hex64>
# SECURITY: Never commit. Never log. Rotate on compromise.
STATION_API_KEY=station_live_PLACEHOLDER_REPLACE_THIS_VALUE

# Request timeout in seconds
BACKEND_REQUEST_TIMEOUT=10

# Heartbeat interval (seconds)
HEARTBEAT_INTERVAL=30

# =============================================================================
# MIDDLEWARE (Room Agent) CONFIG
# =============================================================================

# Port for local WebSocket server (UE connects to this)
AGENT_WS_PORT=8080

# WebSocket path
AGENT_WS_PATH=/ws/laser

# SQLite database path for event buffering
AGENT_BUFFER_DB=./agent_buffer.db

# Max pending events before dropping old ones (memory protection)
AGENT_BUFFER_MAX_EVENTS=10000

# Retry strategy for backend calls
AGENT_RETRY_MAX_ATTEMPTS=10
AGENT_RETRY_INITIAL_BACKOFF_MS=1000
AGENT_RETRY_MAX_BACKOFF_MS=60000

# Log level
AGENT_LOG_LEVEL=info
# One of: debug | info | warn | error

# =============================================================================
# HARDWARE (Laser Controller)
# =============================================================================

# Serial port (Windows)
LASER_SERIAL_PORT=COM3

# Baud rate
LASER_SERIAL_BAUDRATE=115200

# Controller reconnect interval if disconnected (seconds)
LASER_RECONNECT_INTERVAL=5

# =============================================================================
# UE (Unreal Engine Game Client)
# =============================================================================

# Build version (updated per release)
UE_BUILD_VERSION=1.0.0

# UE project executable path (for auto-launch via middleware)
# Optional - can be started manually
UE_EXECUTABLE_PATH=C:\Program Files\OYNA\Lasers\Binaries\Win64\OYNA_Lasers.exe

# =============================================================================
# TIMING
# =============================================================================

# Default session duration (seconds)
DEFAULT_SESSION_DURATION=600

# Timeout for session in WAITING status (seconds)
# If nobody joins in this time - session auto-cancelled
SESSION_WAITING_TIMEOUT=600

# Level duration override (seconds, 0 = use game default 90s)
LEVEL_DURATION_OVERRIDE=0

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable live life_lost events streaming
FEATURE_LIVE_LIFE_LOST=false

# Enable local admin UI in UE
FEATURE_UE_ADMIN_UI=false

# Enable debug/replay log of all WS messages
FEATURE_DEBUG_LOG_WS=false

# =============================================================================
# MONITORING (optional)
# =============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Metrics endpoint (Prometheus-compatible)
METRICS_PORT=9090
METRICS_ENABLED=false

# =============================================================================
# TIMEZONE & LOCALE
# =============================================================================

TZ=Asia/Almaty
LOCALE=ru_RU.UTF-8
