# Database — same Postgres instance as CRM backend
DATABASE_URL="postgresql://user:password@localhost:5432/oyna_db"

# JWT secrets — use DIFFERENT secrets from CRM backend for security
JWT_ACCESS_SECRET="client-access-secret-change-me"
JWT_REFRESH_SECRET="client-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3002
